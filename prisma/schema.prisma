// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ENUM for user roles
enum Role {
  admin
  vendor
  customer
}

model User {
  id              String   @id @db.Text
  name            String
  email           String   @unique
  emailVerified   Boolean  @default(false)

  // Custom fields
  role            Role     @default(customer)
  imageCldPubId   String?
  image           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  sessions        Session[]
  accounts        Account[]
  productsCreated Product[] @relation("ProductCreatedBy")
  productsUpdated Product[] @relation("ProductUpdatedBy")
}

model Department {
  id              Int       @id @default(autoincrement())
  name            String
  slug            String    @unique
  metaTitle       String?   
  metaDescription String?
  active          Boolean   @default(true)
  bannerCldPubId  String?
  bannerUrl       String?
  bannerAltText   String?
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  categories      Category[]
  products        Product[]
}

model Category {
  id           Int       @id @default(autoincrement())
  name         String
  slug           String    @unique
  departmentId Int
  department   Department @relation(fields: [departmentId], references: [id])

  parentId Int?
  parent   Category?  @relation("CategoryParent", fields: [parentId], references: [id])
  children Category[] @relation("CategoryParent")

  active    Boolean   @default(true)
  bannerCldPubId  String?
  bannerUrl       String?
  bannerAltText   String?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]

  @@unique([name, departmentId])
}

model Product {
  id             Int       @id @default(autoincrement())
  name           String  
  slug           String    @unique
  description    String
  images         ProductImage[]
  departmentId   Int
  department     Department @relation(fields: [departmentId], references: [id])
  categoryId     Int
  category       Category   @relation(fields: [categoryId], references: [id])
  status         String
  price          Decimal   @db.Decimal(20, 4)
  quantity       Int?
  metaTitle      String?
  metaDescription String?
  hasVariations  Boolean   @default(false)
  createdBy      String   @db.Text
  createdByUser  User      @relation("ProductCreatedBy", fields: [createdBy], references: [id])
  updatedBy      String   @db.Text
  updatedByUser  User      @relation("ProductUpdatedBy", fields: [updatedBy], references: [id])
  deletedAt      DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([status])
  @@index([hasVariations])
}

model ProductImage {
  id              Int       @id @default(autoincrement())

  imageUrl        String
  imageCldPubId   String

  imageAltText    String

  productId       Int
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  isPrimary       Boolean  @default(false) // main image
  order           Int      @default(0)     // for sorting

  createdAt       DateTime @default(now())
}

model Session {
  id          String   @id @db.Text
  userId      String   @db.Text
  token       String   @unique
  expiresAt   DateTime
  ipAddress   String?
  userAgent   String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], name: "idx_session_userId")
}

model Account {
  id                        String   @id @db.Text
  userId                    String   @db.Text
  accountId                 String
  providerId                String

  accessToken               String?
  refreshToken              String?
  accessTokenExpiresAt      DateTime?
  refreshTokenExpiresAt     DateTime?
  scope                     String?
  idToken                   String?
  password                  String?

  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  // Relations
  user                      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], name: "idx_account_userId")
  @@unique([providerId, accountId], name: "uq_account_provider_account")
}

model Verification {
  id          String   @id @db.Text
  identifier  String
  value       String
  expiresAt   DateTime

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([identifier], name: "idx_verification_identifier")
}